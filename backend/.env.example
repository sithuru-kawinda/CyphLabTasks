# MySQL connection string. For local dev with the root docker-compose.yml:
DATABASE_URL="mysql://root:root@localhost:3306/cyphlab"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"

PORT=4000

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN="http://localhost:3000"

# Set to "true" in production (HTTPS) deployments so the auth cookie requires HTTPS
COOKIE_SECURE="false"
